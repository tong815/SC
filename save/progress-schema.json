{
  "purpose": "Documents the permanent save structure for Exam Visualizer. User save files are downloaded by the browser and are not stored in this folder.",
  "concept": {
    "configuration": "Configuration tells the software how to behave.",
    "state": "State tells the software what has already happened.",
    "questionsAreNotSaved": "Questions are not saved because questions are not world state. Questions are curriculum challenges. They change the world, and the save file records the result of those changes."
  },
  "currentSaveFileShape": {
    "compatibilityNote": "The runtime keeps a legacy-compatible progress object so older saves still load. New saves also include metadata.curriculum as the clear configuration reference.",
    "appName": "Exam Visualizer",
    "version": "3.0",
    "metadata": {
      "version": "3.0",
      "curriculum": "easy | difficult",
      "meaning": "The selected learning path. This is configuration metadata, not ordinary world progress."
    },
    "savedAt": "ISO timestamp",
    "progress": {
      "statistics": {
        "totalQuestionsAnswered": "number",
        "totalCorrectAnswers": "number",
        "totalWrongAnswers": "number",
        "answeredQuestionIds": "string[]",
        "correctQuestionIds": "string[]",
        "wrongQuestionIds": "string[]",
        "topicStats": {
          "<topic>": {
            "answered": "number",
            "correct": "number",
            "wrong": "number"
          }
        }
      },
      "team": {
        "location": "progress.gameProgress.team",
        "size": "number",
        "members": "string[]"
      },
      "worldState": {
        "location": "progress.gameProgress",
        "playerPosition": {
          "x": "number",
          "y": "number"
        },
        "clearedTowerIds": "string[]",
        "towerProgress": {
          "<towerId>": {
            "cleared": "boolean",
            "clearCount": "number",
            "bestRunProgress": "number",
            "lastPlayedAt": "ISO timestamp | null"
          }
        },
        "keyFragments": "string[]",
        "chronicles": {
          "unlockedChronicleIds": "string[]",
          "readChronicleIds": "string[]",
          "currentChronicleId": "string | null",
          "lastUnlockedChronicleId": "string | null"
        },
        "hasCentralTowerKey": "boolean",
        "centralTowerUnlocked": "boolean"
      },
      "legacyConfigurationReference": {
        "field": "progress.gameProgress.difficulty",
        "meaning": "Kept for runtime and old-save compatibility. Conceptually this mirrors metadata.curriculum."
      }
    }
  },
  "oldSaveNormalization": {
    "metadata.curriculum": "preferred when present",
    "progress.metadata.curriculum": "accepted for compatibility",
    "progress.gameProgress.difficulty": "accepted from older saves",
    "progress.difficulty": "accepted from older saves",
    "missingOrInvalidCurriculum": "defaults to easy"
  },
  "notSaved": [
    "current tower HP",
    "current streak",
    "current Seal Energy run state",
    "current shuffled question deck",
    "current question",
    "currently opened Chronicle screen",
    "question pool contents"
  ]
}
